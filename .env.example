# ==============================================================================
# Keycloak Agent Environment Configuration
# ==============================================================================

# --- Connection ---
# Keycloak Base Admin URL
KEYCLOAK_URL=http://localhost:8080
# Alias for the base URL (fallback when KEYCLOAK_URL is unset)
# KEYCLOAK_AGENT_BASE_URL=http://localhost:8080
# Keycloak realm name
KEYCLOAK_REALM=master
# Verify TLS certificates on outbound calls
KEYCLOAK_AGENT_SSL_VERIFY=True

# --- Admin credentials (basic / legacy auth) ---
# Admin account username
KEYCLOAK_AGENT_USERNAME=admin
# Admin account password
KEYCLOAK_AGENT_PASSWORD=admin_secure_password
# Static bearer token (fallback for tests / legacy deploys)
# KEYCLOAK_TOKEN=

# --- Service-account client credentials (preferred admin auth) ---
# A service-account client whose bearer is minted from Keycloak's token endpoint
# and auto-refreshed. Set both to use client-credentials instead of basic auth.
# KEYCLOAK_CLIENT_ID=
# KEYCLOAK_CLIENT_SECRET=

# --- Tool Surface ---
# MCP_TOOL_MODE selects which tools are exposed: condensed (default, action-routed
# tools) | verbose (1:1 per-operation tools) | both.
# MCP_TOOL_MODE=condensed

# --- Tool Toggle Switches (per-domain <DOMAIN>TOOL; set False to disable) ---
# These names match the authoritative "Toggle Env Var" column in the README
# MCP tools table (condensed action-routed surface).
ATTACK_DETECTIONTOOL=True
AUTHENTICATIONTOOL=True
CLIENTSTOOL=True
COMPONENTSTOOL=True
GROUPSTOOL=True
IDPSTOOL=True
INFOTOOL=True
ORGANIZATIONSTOOL=True
REALMSTOOL=True
ROLESTOOL=True
USERSTOOL=True
